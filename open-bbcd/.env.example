# Database
DATABASE_URL=postgres://openbbcd:openbbcd@localhost:5432/openbbcd?sslmode=disable

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Discovery upload storage (local disk; will be replaced by S3 later)
DISCOVERY_STORAGE_DIR=./data/discovery
DISCOVERY_MAX_UPLOAD_MB=50

# Anthropic chat runtime (required when /agents/{id}/chat/... is used)
ANTHROPIC_API_KEY=
OPENBBC_DEFAULT_MODEL=claude-sonnet-4-6
OPENBBC_MAX_TOKENS=4096

# Chat transport + orchestrator loop bounds
OPENBBC_CHAT_TRANSPORT=agui
OPENBBC_MAX_TOOL_ROUNDS=10
